@{
    Layout = "_Layout";
}
<style>
    /* =========================
       FULL PAGE LAYOUT FIX
    ========================= */

    html, body {
        height: 100%;
    }

    body {
        display: flex;
        flex-direction: column;
    }

    /* Main content auto adjust */
    main {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px;
    }

    /* =========================
       LOGIN CARD
    ========================= */

    .login-wrapper {
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .form-box {
        background: #ffffff;
        width: 100%;
        max-width: 360px; /* smaller card */
        padding: 30px 25px; /* reduced padding */
        border-radius: 14px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.12);
        text-align: center;
    }

        .form-box h2 {
            margin-bottom: 20px;
            font-size: 22px; /* reduced */
        }

        /* Smaller Inputs */
        .form-box input {
            width: 100%;
            padding: 10px 12px; /* reduced height */
            margin-bottom: 15px;
            border-radius: 6px;
            border: 1px solid #ccc;
            font-size: 14px;
        }

            .form-box input:focus {
                outline: none;
                border-color: #4f6fa1;
            }

    /* Smaller Button */
    .form-btn {
        width: 100%;
        padding: 9px; /* reduced */
        background: #4f6fa1;
        color: #fff;
        border: none;
        border-radius: 6px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
    }

        .form-btn:hover {
            background: #3d5c8c;
        }

    /* Error */
    .error-msg {
        margin-top: 10px;
        color: red;
        font-size: 13px;
    }


    /* =========================
       FOOTER FIX
    ========================= */

    footer {
        background: #4f6fa1;
        color: white;
        text-align: center;
        padding: 12px;
    }


    /* =========================
       RESPONSIVE
    ========================= */

    @@media (max-width: 480px) {

        .form-box {
            max-width: 100%;
            padding: 25px 18px;
        }
    }
</style>

<div class="login-wrapper">
    <div class="form-box">
        <h2>Admin Login</h2>

        <form method="post">
            <input type="text" name="username" placeholder="Username" required />
            <input type="password" name="password" placeholder="Password" required />
            <button type="submit" class="form-btn">Login</button>
        </form>

        <div class="error-msg">@ViewBag.Error</div>
    </div>
</div>